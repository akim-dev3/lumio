# Telegram Bot token from @BotFather
BOT_TOKEN=

# OpenRouter API key (free models available): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override LLM model. Defaults to a free-tier DeepSeek model.
# Browse free models: https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Public URL where the Mini App SPA is hosted (Render static site)
WEBAPP_URL=https://lumio-webapp.onrender.com

# Public URL of the bot service (Render web service) — used for webhook
WEBHOOK_URL=https://lumio-bot.onrender.com

# Local path to SQLite database file
DATABASE_PATH=./lumio.db

# Optional: port for the aiohttp webhook server (Render sets PORT automatically)
PORT=8080

# Optional: secret token for webhook verification
WEBHOOK_SECRET=lumio-secret-token
